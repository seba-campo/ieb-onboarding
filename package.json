{
  "name": "challenge-onboarding-fintech",
  "version": "1.0.0",
  "scripts": {
    "install-all": "yarn install && cd backend && yarn install && cd ../frontend && yarn install",
    "dev": "concurrently --names \"backend,frontend\" --prefix-colors \"blue,green\" \"yarn --cwd backend dev\" \"yarn --cwd frontend dev\"",
    "seed": "node backend/seed.js",
    "format": "prettier --write \"backend/src/**/*.ts\" \"frontend/src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"backend/src/**/*.ts\" \"frontend/src/**/*.{ts,tsx}\""
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "prettier": "^3.9.1"
  }
}
